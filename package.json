{
  "name": "string-replacer",
  "displayName": "字符串替换器",
  "description": "在当前文件中执行批量字符串替换",
  "version": "1.1.0",
  "publisher": "HengXin666",
  "repository": {
    "type": "git",
    "url": "https://github.com/HengXin666/vscode-string-replacer.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:*",
    "onCommand:stringReplacer.replace",
    "onCommand:stringReplacer.checkForUpdates",
    "onCommand:stringReplacer.reloadAllWindows"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "stringReplacer.replace",
        "title": "批量替换字符串",
        "category": "字符串替换器"
      },
      {
        "command": "stringReplacer.checkForUpdates",
        "title": "字符串替换器: 检查更新",
        "category": "字符串替换器"
      },
      {
        "command": "stringReplacer.reloadAllWindows",
        "title": "字符串替换器: 重载所有窗口",
        "category": "字符串替换器"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "字符串替换器配置",
      "properties": {
        "stringReplacer.replacements": {
          "type": "object",
          "default": {
            "（": "(",
            "）": ")",
            "，": ", ",
            "？": "? ",
            "！": "! ",
            "；": "; ",
            "：": ": "
          },
          "description": "替换规则 (键为被替换内容，值为目标内容，直接替换)"
        },
        "stringReplacer.trimTrailingSpaces": {
          "type": "boolean",
          "default": false,
          "description": "是否自动去除替换后每行结尾的多余空格"
        },
        "stringReplacer.autoUpdate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "自动从 GitHub Releases 检查字符串替换器更新。"
        },
        "stringReplacer.autoUpdate.checkIntervalHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 168,
          "description": "自动检查更新的间隔（小时）。"
        }
      }
    },
    "keybindings": [
      {
        "command": "stringReplacer.replace",
        "key": "ctrl+alt+/",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "rm -rf out && tsc -p ./ && mkdir -p out/vendor && cp ../vscode-extension-github-updater/dist/index.js out/vendor/githubUpdater.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "check": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0"
  }
}
